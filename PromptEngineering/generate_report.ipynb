pdf.subsection("4.2  Technique 1 — Zero-Shot Prompting")
pdf.body(
    "The simplest form of prompting: a direct question with no examples, role, or structure."
)
pdf.code_block('Prompt: "Explain the causes of World War I."')
pdf.response_block(
